generator client {
    provider = "prisma-client-js"
    output   = "../generated/prisma"
}

datasource db {
    provider = "postgresql"
    url      = env("DATABASE_URL")
}

enum UserRole {
    MEMBER
    ADMIN
}

model Account {
    id                       String  @id @default(cuid())
    userId                   String
    type                     String
    provider                 String
    providerAccountId        String
    refresh_token            String?
    access_token             String?
    expires_at               Int?
    token_type               String?
    scope                    String?
    id_token                 String?
    session_state            String?
    user                     User    @relation(fields: [userId], references: [id], onDelete: Cascade)
    refresh_token_expires_in Int?

    @@unique([provider, providerAccountId])
}

model Session {
    id           String   @id @default(cuid())
    sessionToken String   @unique
    userId       String
    expires      DateTime
    user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model User {
    id            String    @id @default(cuid())
    name          String?
    email         String?   @unique
    emailVerified DateTime?
    image         String?
    city          String?
    passwordHash  String?
    role          UserRole  @default(MEMBER)
    accounts      Account[]
    sessions      Session[]
    reviews       Review[]
    savedRoutes   SavedRoute[]
}

model VerificationToken {
    identifier String
    token      String   @unique
    expires    DateTime

    @@unique([identifier, token])
}

model Brewery {
    id          String      @id @default(cuid())
    slug        String      @unique
    name        String
    city        String
    country     String
    latitude    Float
    longitude   Float
    description String
    specialty   String
    heroBeer    String?
    website     String?
    tags        String[]
    beers       Beer[]
    routeStops  RouteStop[]
    createdAt   DateTime    @default(now())
    updatedAt   DateTime    @updatedAt
}

model Beer {
    id          String    @id @default(cuid())
    slug        String    @unique
    name        String
    style       String
    abv         Float
    ibu         Int?
    description String
    featured    Boolean   @default(false)
    breweryId   String
    brewery     Brewery   @relation(fields: [breweryId], references: [id], onDelete: Cascade)
    reviews     Review[]
    createdAt   DateTime  @default(now())
    updatedAt   DateTime  @updatedAt

    @@index([breweryId])
    @@index([style])
}

model Review {
    id         String    @id @default(cuid())
    beerId     String
    beer       Beer      @relation(fields: [beerId], references: [id], onDelete: Cascade)
    userId     String?
    user       User?     @relation(fields: [userId], references: [id], onDelete: SetNull)
    authorName String
    rating     Int
    title      String
    body       String
    visitedAt  DateTime?
    published  Boolean   @default(true)
    createdAt  DateTime  @default(now())

    @@index([beerId])
    @@index([rating])
}

model Route {
    id              String      @id @default(cuid())
    slug            String      @unique
    name            String
    city            String
    vibe            String
    summary         String
    durationMinutes Int
    distanceKm      Float
    createdAt       DateTime    @default(now())
    updatedAt       DateTime    @updatedAt
    stops           RouteStop[]
    savedBy         SavedRoute[]

    @@index([city])
    @@index([vibe])
}

model SavedRoute {
    id        String   @id @default(cuid())
    userId    String
    routeId   String
    note      String?
    createdAt DateTime @default(now())
    route     Route    @relation(fields: [routeId], references: [id], onDelete: Cascade)
    user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

    @@unique([userId, routeId])
    @@index([routeId])
}

model RouteStop {
    id              String   @id @default(cuid())
    routeId         String
    breweryId       String
    position        Int
    recommendedPour String?
    route           Route    @relation(fields: [routeId], references: [id], onDelete: Cascade)
    brewery         Brewery  @relation(fields: [breweryId], references: [id], onDelete: Cascade)

    @@unique([routeId, position])
    @@index([breweryId])
}
